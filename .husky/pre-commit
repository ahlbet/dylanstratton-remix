#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Format code first and stage the changes, excluding .venv
npm run format -- --ignore-path .prettierignore
git add .

# Then run linting and type checking
npm run lint
npm run typecheck

# Run both JavaScript and Python tests
echo "Running JavaScript tests..."
npm run test

echo "Running Python tests..."
npm run pytest
